# Auto-detect text files and normalize line endings
* text=auto

# Explicitly declare binary files to prevent corruption
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2binary
*.zip binary
*.gz binary
*.tar binary
*.apk binary
*.aab binary

# Force LF for JS/JSON/config files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.sh text eol=lf
